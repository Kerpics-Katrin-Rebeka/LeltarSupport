<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LeltarSupportMauiApp.ViewModels"
             x:Class="LeltarSupportMauiApp.Views.LoginView"
             x:DataType="viewmodels:LoginViewModel"
             Title="Login">
    <Grid MaximumWidthRequest="400" BackgroundColor="LightBlue" Padding="20">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
            <Label Text="Login" FontSize="Title" HorizontalOptions="Center" />
            <Entry Placeholder="Email" Text="{Binding Email}" BackgroundColor="White" WidthRequest="130"/>
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" BackgroundColor="White" WidthRequest="130" />
            <Button Text="Login"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding CanLogin}" />
            <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Tomato" IsVisible="{Binding HasError}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>