<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeltarSupportMauiApp.Views.CartView"
             Title="CartView">

    <ListView x:Name="CartListView"
              CachingStrategy="RecycleElement"
              ItemsSource="{Binding CartItems}">

        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Grid Padding="10" ColumnDefinitions="*, Auto">
                        <VerticalStackLayout>
                            <Label Text="{Binding Product.Name}" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalPrice, StringFormat='{}{0:C}'}"/>
                        </VerticalStackLayout>
                        <ImageButton
                            Source="bin.png"
                            BackgroundColor="Transparent"
                            Grid.Column="1"
                            Command="{Binding BindingContext.RemoveFromCartCommand, Source={x:Reference CartListView}}"
                            CommandParameter="{Binding .}"/>
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>

    </ListView>
</ContentPage>