<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeltarSupportMauiApp.Views.CartView"
             Title="CartView">
    <ListView x:Name="CartListView" CachingStrategy="RecycleElement" ItemsSource="{Binding CartItems}">
        <ListView.ItemTemplate>
            <DataTemplate> 
                <TextCell Text="{Binding Product.Name, StringFormat='{}{0} x {1}', Converter={StaticResource QuantityConverter}}"
                          Detail="{Binding TotalPrice, StringFormat='{}{0:C}'}"/>
            </DataTemplate>
        </ListView.ItemTemplate>    
    </ListView>
</ContentPage>