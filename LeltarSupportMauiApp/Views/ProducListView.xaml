<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LeltarSupportMauiApp.ViewModels"
             xmlns:models="clr-namespace:LeltarSupportMauiApp.Models"
             x:DataType="viewmodels:ProductListViewModel"
             x:Class="LeltarSupportMauiApp.Views.ProductListView"
             x:Name="page"
             Title="Products">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Kosár"
                     IconImageSource="kosar.png"
                     Order="Primary"
                     Command="{Binding CartCommand}" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="MainGrid">
        <CollectionView ItemsSource="{Binding ProductList}"
                SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                         Span="2"
                         HorizontalItemSpacing="10"
                         VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">

                    <Border Margin="10"
                            Padding="12"
                            Stroke="#DDDDDD"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 15"
                            BackgroundColor="White">    

                        <Border.Shadow>
                            <Shadow Brush="#80000F3F"
                            Offset="0,3"
                            Radius="8"
                            Opacity="0.25"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}"
                           FontSize="16"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"/>

                            <Label Text="{Binding Price, StringFormat='{0:C}'}"
                           FontSize="14"
                           TextColor="#2E7D32"/>

                            <Button Text="Add"
                            Clicked="OnAddToCartClicked"
                            FontSize="14"
                            CornerRadius="10"
                            BackgroundColor="#2196F3"
                            TextColor="White"/>
                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Grid x:Name="IsInactiveFor1MinutesPopUp" IsVisible="False" BackgroundColor="#80000000">
            <Border BackgroundColor="White" Padding="20" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="250">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Label Text="You have been inactive for 1 minute. Do you want to continue the order?"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

                    <Button x:Name="ContinuePopUpButton"
                    Text="Continue"
                    Clicked="ContinuePopUpButton_Clicked"/>

                    <Button x:Name="CancelOrderButton" Text="Cancel order" Clicked="CancelOrderButton_Clicked"/>



                </VerticalStackLayout>
            </Border>
        </Grid>
        <Grid x:Name="StartOverlay"
              BackgroundColor="#CC000000"
              IsVisible="True"
              ZIndex="10">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20"
                                 Padding="30">
                <Label Text="Start your order"
                       TextColor="White"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />

                <Label Text="Tap below to continue"
                       TextColor="White"
                       FontSize="18"
                       HorizontalTextAlignment="Center" />

                <Button Text="Start order"
                        Clicked="OnStartOrderClicked"
                        FontSize="24"
                        Padding="30,14" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
