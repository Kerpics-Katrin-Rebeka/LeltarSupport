<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LeltarSupportMauiApp.ViewModels"
             xmlns:models="clr-namespace:LeltarSupportMauiApp.Models"
             x:DataType="viewmodels:ProductListViewModel"
             x:Class="LeltarSupportMauiApp.Views.ProductListView"
             Title="Products"
             >
    <Grid>
        <CollectionView ItemsSource="{Binding ProductList}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedProduct}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductsModel">
                    <Grid Padding="10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0" 
                               Text="{Binding Name}" 
                               FontSize="18" 
                               FontAttributes="Bold"/>
                        <Label Grid.Row="0" Grid.Column="1" 
                               Text="{Binding Price, StringFormat='{0:C}'}" 
                               FontSize="18" 
                               HorizontalOptions="End"/>
                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding Active, StringFormat='Active: {0}'}" 
                               FontSize="14" 
                               TextColor="Gray"/>
                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Text="Add ingredients"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProductListViewModel}}, Path=ProductDetailsCommand}"
                                CommandParameter="{Binding .}"
                                HorizontalOptions="End"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
