<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LeltarSupportMauiApp.ViewModels"
             xmlns:models="clr-namespace:LeltarSupportMauiApp.Models"
             x:DataType="viewmodels:ProductListViewModel"
             x:Class="LeltarSupportMauiApp.Views.ProductListView"
             x:Name="page"
             Title="Products">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Kosár"
                     IconImageSource="kosar.png"
                     Order="Primary"
                     Command="{Binding CartCommand}" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="MainGrid">
        <CollectionView ItemsSource="{Binding ProductList}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <Grid Padding="10"
                          ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto">
                        <Label Grid.Row="0"
                               Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="18"
                               FontAttributes="Bold" />

                        <Label Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding Price, StringFormat='{0:C}'}"
                               FontSize="18"
                               HorizontalOptions="End" />

                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Text="{Binding Active, StringFormat='Active: {0}'}"
                               FontSize="14"
                               TextColor="Gray" />

                        <Button Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Text="Add to cart"
                                Clicked="OnAddToCartClicked"
                                HorizontalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Grid x:Name="IsInactiveFor1MinutesPopUp" IsVisible="False" BackgroundColor="#80000000">
            <Border BackgroundColor="White" Padding="20" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="250">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Label Text="You have been inactive for 1 minute. Do you want to continue the order?"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

                    <Button x:Name="ContinuePopUpButton"
                    Text="Continue"
                    Clicked="ContinuePopUpButton_Clicked"/>

                    <Button x:Name="CancelOrderButton" Text="Cancel order" Clicked="CancelOrderButton_Clicked"/>



                </VerticalStackLayout>
            </Border>
        </Grid>
        <Grid x:Name="StartOverlay"
              BackgroundColor="#CC000000"
              IsVisible="True"
              ZIndex="10">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20"
                                 Padding="30">
                <Label Text="Start your order"
                       TextColor="White"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />

                <Label Text="Tap below to continue"
                       TextColor="White"
                       FontSize="18"
                       HorizontalTextAlignment="Center" />

                <Button Text="Start order"
                        Clicked="OnStartOrderClicked"
                        FontSize="24"
                        Padding="30,14" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
