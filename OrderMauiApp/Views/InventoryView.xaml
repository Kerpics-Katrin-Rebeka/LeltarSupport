<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OrderMauiApp.ViewModels"
             xmlns:models="clr-namespace:OrderMauiApp.Models"
             x:Class="OrderMauiApp.Views.InventoryView"
             Title="Inventory">
    <Grid RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" x:DataType="vm:InventoryViewModel" ItemsSource="{Binding InventoryList}" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Inventory">
                    <Border Margin="10" Padding="12" Stroke="#E0E0E0" StrokeThickness="1.5" StrokeShape="RoundRectangle 15" BackgroundColor="White">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Ingredient.Name}" FontSize="16" FontAttributes="Bold" />

                            <Label FontSize="14">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Stock: " TextColor="Gray" />
                                        <Span Text="{Binding Quantity}" />
                                        <Span Text=" " />
                                        <Span Text="{Binding Ingredient.Unit}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label FontSize="13" TextColor="Gray" Text="{Binding MinimumLevel, StringFormat='Min: {0}'}" />
                            <Label FontSize="13" TextColor="DarkOrange" Text="{Binding PendingAdjustment, StringFormat='Pending change: {0}'}" />

                            <Label FontSize="13" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLowStock}" Value="True">
                                        <Setter Property="Text" Value="LOW STOCK" />
                                        <Setter Property="TextColor" Value="Red" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Change by:" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding ChangeQuantity, Mode=TwoWay}"
                                       Keyboard="Numeric"
                                       Placeholder="1" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="-"
                                        FontSize="14"
                                        BackgroundColor="#007ACC"
                                        TextColor="White"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=DecreaseCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Grid.Column="1"
                                        Text="+"
                                        FontSize="14"
                                        BackgroundColor="#E53935"
                                        TextColor="White"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=IncreaseCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="1" Padding="10" BackgroundColor="White" StrokeThickness="0">
            <Button Text="Save Changes"
                    HeightRequest="50"
                    FontSize="16"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=SaveCommand}" />
        </Border>
    </Grid>
</ContentPage>