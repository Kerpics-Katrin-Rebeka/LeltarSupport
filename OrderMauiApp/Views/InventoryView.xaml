<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OrderMauiApp.ViewModels"
             xmlns:models="clr-namespace:LeltarSupportMauiApp.Models"
             x:Class="OrderMauiApp.Views.InventoryView"
             Title="Inventory">

    <CollectionView ItemsSource="{Binding InventoryList}"
                    SelectionMode="None">
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             Span="2"
                             HorizontalItemSpacing="12"
                             VerticalItemSpacing="12"/>
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Inventory">

                <Border Margin="10"
                        Padding="12"
                        Stroke="#E0E0E0"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 15"
                        BackgroundColor="White">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Ingredient.Name}"
                               FontSize="16"
                               FontAttributes="Bold"/>

                        <Label FontSize="14">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Stock: " TextColor="Gray"/>
                                    <Span Text="{Binding Quantity}"/>
                                    <Span Text=" "/>
                                    <Span Text="{Binding Ingredient.Unit}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Label FontSize="13"
                               TextColor="Gray"
                               Text="{Binding MinimumLevel, StringFormat='Min: {0}'}"/>

                        <Label FontSize="13"
                               FontAttributes="Bold">
                            <Label.Triggers>
                                <!-- Compare IsLowStock boolean to literal True -->
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsLowStock}"
                                             Value="True">
                                    <Setter Property="Text" Value="LOW STOCK"/>
                                    <Setter Property="TextColor" Value="Red"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                    </VerticalStackLayout>
                </Border>

            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>